# Application
APP_ENV=development
DATA_DIR=./data
LOG_LEVEL=INFO

# API / MCP
API_HOST=0.0.0.0
API_PORT=8090
MCP_TRANSPORT=http

# Ollama (local LLM)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_SYNTHESIS_MODEL=qwen2.5:3b
OLLAMA_VLM_MODEL=qwen2.5-vl:7b

# Gemini / Vertex AI (cloud fallback)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=europe-west1
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash
# GOOGLE_APPLICATION_CREDENTIALS=  # optional local SA JSON path

# Hardware profile override (auto|integrated|discrete)
HARDWARE_PROFILE=auto

# QA loop
QA_MAX_ITERATIONS=3
QA_RENDER_DPI=150

# Frontend
UI_HOST=0.0.0.0
UI_PORT=8091
