# Application
APP_ENV=development
DATA_DIR=./data
LOG_LEVEL=INFO

# API / MCP
API_HOST=0.0.0.0
API_PORT=8090
MCP_TRANSPORT=http

# Ollama (local LLM)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_SYNTHESIS_MODEL=qwen2.5:7b
OLLAMA_VLM_MODEL=qwen2.5vl:7b
OLLAMA_SUPPORTS_VLM=true
OLLAMA_NUM_PREDICT=4096
OLLAMA_NUM_CTX=32768
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_SOURCE_CONTEXT_CHARS=32000

# Gemini / Vertex AI (cloud fallback)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=europe-west1
GEMINI_MODEL=gemini-2.5-pro
GEMINI_VISION_MODEL=gemini-2.5-flash
# GOOGLE_APPLICATION_CREDENTIALS=  # optional local SA JSON path

# Cloud LLM consent (operator default; users override per-request in UI)
ALLOW_CLOUD_LLM_DEFAULT=false

# Hardware profile override (auto|integrated|discrete)
HARDWARE_PROFILE=auto

# QA loop
QA_MAX_ITERATIONS=3
QA_RENDER_DPI=150

# Frontend
UI_HOST=0.0.0.0
UI_PORT=8091

# PDF Toolbox MCP (source document extraction)
PDF_MCP_URL=http://host.docker.internal:3005/mcp
PDF_MCP_WORKSPACE_DIR=../pdf/mcp-workspace

# Context7 (IT-topic documentation enrichment)
CONTEXT7_MCP_URL=https://mcp.context7.com/mcp
CONTEXT7_API_KEY=
CONTEXT7_ENABLED=true
CONTEXT7_MAX_TECHS=3

# Source digest before synthesis
ENABLE_DIGEST_PHASE=true
DIGEST_CHUNK_CHARS=8000
